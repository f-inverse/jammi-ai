% --- The wire contract: gRPC status codes --------------------------------------
% The canonical typed-error vocabulary on the wire. The §3.8 channel error-taxonomy
% chapter cites this for the semantics of ALREADY_EXISTS (the entity a client
% tried to create already exists), NOT_FOUND (the requested entity was not found),
% FAILED_PRECONDITION (the operation was rejected because the system is not in the
% state the operation requires), and INVALID_ARGUMENT (a problematic argument
% regardless of system state) — the four codes the channel registry maps its
% failures onto under #193, instead of INTERNAL (an internal-invariant fault).
% Verified against the official gRPC documentation (grpc.io/docs/guides/status-codes),
% which mirrors the google.rpc.Code enum.
@misc{grpcstatuscodes,
  title        = {Status Codes},
  author       = {{The gRPC Authors}},
  howpublished = {gRPC documentation, \url{https://grpc.io/docs/guides/status-codes/}},
  year         = {2024}
}

% --- BYO-auth seam: the generic credential primitives -------------------------

% HMAC — the keyed-hash the §3.5 BYO-auth worked example signs its generic bearer
% token with (HMAC-SHA256 over "<subject>.<tenant>"). The construction is what
% makes the tenant claim INSIDE the token unforgeable without the shared key, so a
% verified claim — not a caller-asserted header — derives the tenant. Cited for the
% MAC primitive the gateway verifies; verified against the RFC Editor record
% (rfc-editor.org/info/rfc2104): H. Krawczyk, M. Bellare, R. Canetti, February 1997.
@misc{rfc2104,
  title        = {{HMAC}: Keyed-Hashing for Message Authentication},
  author       = {Krawczyk, Hugo and Bellare, Mihir and Canetti, Ran},
  howpublished = {RFC 2104, Internet Engineering Task Force},
  month        = feb,
  year         = {1997},
  note         = {DOI 10.17487/RFC2104, \url{https://www.rfc-editor.org/info/rfc2104}}
}

% Bearer Token Usage — the credential presentation pattern the §3.5 BYO-auth seam
% uses: the caller presents an opaque bearer token on the Authorization header, and
% any party in possession of it can use it (so it is carried over a protected
% channel and verified by the gateway). Cited for the bearer-token usage the generic
% credential follows; verified against the RFC Editor record
% (rfc-editor.org/info/rfc6750): M. Jones, D. Hardt, October 2012.
@misc{rfc6750,
  title        = {The {OAuth} 2.0 Authorization Framework: Bearer Token Usage},
  author       = {Jones, Michael B. and Hardt, Dick},
  howpublished = {RFC 6750, Internet Engineering Task Force},
  month        = oct,
  year         = {2012},
  note         = {DOI 10.17487/RFC6750, \url{https://www.rfc-editor.org/info/rfc6750}}
}
