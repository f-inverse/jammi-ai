# Devcontainer
.devcontainer/.bash_history

# Rust
/target
*.db
*.db-wal
*.db-shm

# Generated by Cargo
debug
**/*.rs.bk
*.pdb

# Cargo mutants
**/mutants.out*/

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
.venv/
*.so
# maturin develop drops a debug-symbols bundle next to the extension module
*.dSYM/

# Test artifacts
/tmp/jammi-test-*/

# HuggingFace cache (large, downloaded at runtime)
.cache/

# mdbook build output
docs/guide/book/

# TypeScript client (@jammi/client) — generated-at-build, never committed.
# The proto stays the single source; `src/gen` is emitted by `buf generate`.
clients/typescript/node_modules/
clients/typescript/src/gen/

# Python client (jammi-client) — generated-at-build, never committed.
# The proto stays the single source; `_generated/` is emitted by `make generate`.
clients/python/jammi_client/_generated/
clients/python/.venv/
clients/python/dist/
clients/python/build/
clients/python/*.egg-info/

# Server wheels (jammi-server / jammi-server-cu12) — the compiled `jammi-server`
# binary is injected under `jammi_server/bin/` by CI at build time, never
# committed. The `.gitkeep` keeps the directory; the binary itself is ignored.
packaging/*/jammi_server/bin/jammi-server
packaging/*/dist/
packaging/*/build/

# In-repo cargo target + tmp dirs (CARGO_TARGET_DIR / TMPDIR for local gating)
.cargo-target/
.target/
.tmp/

# Claude
.claude
CLAUDE.md
docs/plans/*
# Maintainer roadmap / journey docs are tracked despite the docs/plans/ rule.
!docs/plans/52-maintainer-roadmap/
docs/superpowers/
docs/IMPLEMENTATION.md
docs/specs/